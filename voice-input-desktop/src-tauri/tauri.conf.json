{
  "$schema": "https://schema.tauri.app/config/2.0",
  "productName": "语音输入助手",
  "version": "0.0.2",
  "identifier": "com.voiceinput.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "语音输入助手",
        "width": 800,
        "height": 600,
        "visible": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
